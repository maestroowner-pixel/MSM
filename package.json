{
  "name": "marine.safety.manager.mac",
  "version": "1.0.0",
  "description": "Ship LSA & FFE safety-equipment inventory and inspection manager — macOS (react-native-macos)",
  "main": "index.tsx",
  "scripts": {
    "start": "expo start",
    "start:macos": "RN_PLATFORM=macos expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "macos": "RN_PLATFORM=macos react-native run-macos",
    "web": "expo start --web",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "typecheck": "tsc --noEmit",
    "aab": "node scripts/patch-android-signing.js && node scripts/patch-android-minify.js && cd android && ./gradlew bundleRelease",
    "postinstall": "node scripts/patch-rn.js && node scripts/patch-android-signing.js && node scripts/patch-android-minify.js"
  },
  "keywords": [
    "maritime",
    "safety",
    "LSA",
    "FFE",
    "FIFI",
    "lifesaving",
    "firefighting",
    "inventory",
    "inspection",
    "vessel",
    "ship"
  ],
  "author": "Mykhaylo Osypov <kukalab@icloud.com>",
  "license": "PROPRIETARY",
  "private": true,
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-picker/picker": "2.11.1",
    "@react-navigation/bottom-tabs": "^6.5.11",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/stack": "^6.3.20",
    "expo": "^54.0.0",
    "expo-av": "~16.0.8",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.12",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-notifications": "~0.32.17",
    "expo-print": "~15.0.8",
    "expo-screen-orientation": "~9.0.9",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "firebase": "^12.12.1",
    "jszip": "^3.10.1",
    "react": "19.1.4",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@react-native-community/cli": "^20.0.2",
    "@react-native/babel-preset": "^0.81.5",
    "@react-native/metro-config": "^0.81.5",
    "@types/react": "~19.1.10",
    "babel-preset-expo": "~54.0.10",
    "react-native-macos": "0.81.5",
    "typescript": "~5.9.2"
  }
}
